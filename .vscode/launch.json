{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "App (Linux Debug)",
			"type": "cppdbg",
			"request": "launch",
			"program": "${workspaceFolder}/build-linux-debug/App/App",
			"args": [
				"res/meshes/Player.mesh",
				"res/meshes/Player.gltf",
				"res/textures/D_Main_character_EC.png"
			],
			"stopAtEntry": false,
			"cwd": "${workspaceFolder}/build-linux-debug/App",
			"environment": [],
			"externalConsole": false,
			"MIMode": "gdb",
			"setupCommands": [
				{
					"description": "Enable pretty-printing",
					"text": "-enable-pretty-printing",
					"ignoreFailures": true
				}
			],
			"miDebuggerPath": "/usr/bin/gdb",
			"preLaunchTask": "Build All (Linux Debug)"
		},
		{
			"name": "App (Linux Release)",
			"type": "cppdbg",
			"request": "launch",
			"program": "${workspaceFolder}/build-linux-release/App/App",
			"args": [
				"res/meshes/Player.mesh",
				"res/models/Player.gltf",
				"res/textures/D_Main_character_EC.png"
			],
			"stopAtEntry": false,
			"cwd": "${workspaceFolder}/build-linux-release/App",
			"environment": [],
			"externalConsole": false,
			"MIMode": "gdb",
			"setupCommands": [
				{
					"description": "Enable pretty-printing",
					"text": "-enable-pretty-printing",
					"ignoreFailures": true
				}
			],
			"miDebuggerPath": "/usr/bin/gdb",
			"preLaunchTask": "Build All (Linux Release)"
		}
	]
}
